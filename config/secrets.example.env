# Secrets are split into a SHARED base + per-PROFILE files, so you can keep separate
# personal vs business accounts and switch between them.
#
#   config/secrets.env            <- shared across every profile (Ahrefs, OpenRouter, PSI). THIS FILE.
#   config/secrets.personal.env   <- personal-only keys (e.g. DataForSEO personal account)
#   config/secrets.business.env   <- business-only keys (e.g. DataForSEO business account)
#   config/active-profile         <- one word: which profile is active (default: personal)
#
# Switch profiles:  ./bin/mkt profile use business   (or: personal)   /   ./bin/mkt profile show
# Or set MKT_PROFILE=business in the environment for a one-off.
# The active profile file loads OVER this shared base (profile values win).
# Copy this to config/secrets.env and the two profile files; all are gitignored.

# ============ SHARED (config/secrets.env) ============
# --- Ahrefs (CLI fallback; MCP is primary when connected) ---
AHREFS_API_KEY=

# --- OpenRouter (web-research + AI-citation probe; Perplexity Sonar) ---
OPENROUTER_API_KEY=

# --- Multi-source domain authority (tools/seo/authority.py) ---
# Open PageRank = FREE key from https://www.domcop.com/openpagerank/ (0-10 link authority, 100 domains/call)
OPENPAGERANK_API_KEY=
# Moz Links API = Domain Authority 0-100 (the client-recognized number). Single API token OR id+secret.
MOZ_TOKEN=
MOZ_ACCESS_ID=
MOZ_SECRET_KEY=

# --- PageSpeed Insights / CrUX (optional) ---
GOOGLE_PSI_API_KEY=

# --- Public social/profile scraping (internal only; never named in client reports) ---
APIFY_API_TOKEN=

# --- PredictLeads (competitor funding + hiring momentum; free tier works) ---
PREDICTLEADS_API_KEY=
PREDICTLEADS_API_TOKEN=

# --- Google Search Console / GA4 (optional; service-account path + property) ---
GOOGLE_APPLICATION_CREDENTIALS=
GA4_PROPERTY_ID=


# ============ PER-PROFILE (config/secrets.<profile>.env) ============
# DataForSEO is the committed data backbone (SERP incl. AI Overviews, keyword volume, backlinks,
# OnPage). Put each account's login/password in its profile file, NOT here.
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=
